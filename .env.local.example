# Supabase — get these from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email — your Ionos email credentials
EMAIL_USER=you@yourdomain.com
EMAIL_PASS=your-ionos-email-password
ADMIN_EMAIL=you@yourdomain.com

# Admin dashboard password (you pick this)
ADMIN_SECRET=your-admin-password-here
